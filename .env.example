# ──────────────────────────────────────────────────────────────
#  EcoMind — Environment Variables
#  Copy this file to ".env" and fill in your real values.
#      cp .env.example .env        (macOS / Linux)
#      copy .env.example .env      (Windows)
# ──────────────────────────────────────────────────────────────

# Your NVIDIA NIM API key.
# Get a free key at https://build.nvidia.com (1000 free calls/month, no card required).
# This is a placeholder — never commit your real key.
NVIDIA_API_KEY=nvapi-your-real-key-here

# The NVIDIA model used for all AI features.
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# NVIDIA NIM base endpoint (rarely needs changing).
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Port the local server listens on.
PORT=3000
